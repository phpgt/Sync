{
	"name": "phpgt/sync",
	"description": "Synchronise two directories.",

	"require": {
		"php": ">=8.0",
		"phpgt/cli": "^1.3",
		"webmozart/glob": "4.4.*"
	},

	"require-dev": {
		"phpstan/phpstan": "^1.10",
		"phpunit/phpunit": "^10.1",
		"phpmd/phpmd": "^2.13",
		"squizlabs/php_codesniffer": "^3.7"
	},

	"autoload": {
		"psr-4": {
			"Gt\\Sync\\": "./src"
		}
	},

	"autoload-dev": {
		"psr-4": {
			"Gt\\Sync\\Test\\": "./test/phpunit"
		}
	},

	"bin": [
		"bin/sync"
	],

	"scripts": {
		"phpunit": "vendor/bin/phpunit --configuration phpunit.xml",
		"phpstan": "vendor/bin/phpstan analyse --level 6 src --memory-limit 256M",
		"phpcs": "vendor/bin/phpcs src --standard=phpcs.xml",
		"phpmd": "vendor/bin/phpmd src/ text phpmd.xml",
		"test": [
			"@phpunit",
			"@phpstan",
			"@phpcs",
			"@phpmd"
		]
	},

	"keywords": [
		"rsync",
		"synchronise",
		"synchronize",
		"copy",
		"recursive",
		"filesystem",
		"file",
		"files"
	],

	"funding": [
		{
			"type": "github",
			"url": "https://github.com/sponsors/phpgt"
		}
	]
}
